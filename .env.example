# Copy to .env (or set as Fly secrets) and fill in.

# Get from @BotFather in Telegram: /newbot -> save the token here.
TELEGRAM_BOT_TOKEN=

# Your personal chat id. Open https://t.me/userinfobot, send /start, copy the id.
# Use a comma-separated list to broadcast to multiple chats / a group / a channel.
TELEGRAM_CHAT_IDS=

# Optional: Coinglass v3 API key (free tier works). Leave empty to use Binance-only data.
# COINGLASS_API_KEY=

# Path to YAML config (default: ./config.yaml inside the working dir).
# CRYPTO_FLOW_BOT_CONFIG=/app/config.yaml

# Where the bot keeps persistent state (open virtual positions, last alert times, etc.)
# CRYPTO_FLOW_BOT_STATE_DIR=/app/state

# Log directory for JSONL alert/position records used for later backtests.
# CRYPTO_FLOW_BOT_LOG_DIR=/app/logs

# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
# CRYPTO_FLOW_BOT_LOG_LEVEL=INFO
